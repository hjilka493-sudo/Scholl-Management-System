<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE">

    <!-- Scroll Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_nav">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Top Orange Curve -->
            <View
                android:id="@+id/top_bg"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/top_teacher_log"/>

            <!-- Profile Circle -->
            <ImageView
                android:id="@+id/profile_image"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="120dp"
                android:background="@drawable/circle_teacher_t_log"
                android:padding="25dp"
                android:src="@drawable/ic_user"/>

            <!-- Welcome Card -->
            <LinearLayout
                android:id="@+id/welcome_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/profile_image"
                android:layout_margin="20dp"
                android:background="@drawable/card_orange_t_log"
                android:orientation="vertical"
                android:padding="15dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tv_wel"
                    android:text="Welcome Message →"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="The standard Lorem Ipsum passage"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Grid Menu -->
            <GridLayout
                android:id="@+id/menu_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/welcome_card"
                android:layout_marginTop="10dp"
                android:columnCount="3"
                android:padding="10dp"
                android:alignmentMode="alignMargins"
                android:useDefaultMargins="true">

                <!-- Attendance -->
                <LinearLayout
                    android:id="@+id/menu_attendance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="75dp"
                        android:layout_height="75dp"
                        android:background="@drawable/menu_box_t_log"
                        android:padding="18dp"
                        android:src="@drawable/ic_attendance"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Attendance"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>


                <!-- Homework -->
                <LinearLayout
                    android:id="@+id/menu_homework"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="75dp"
                        android:layout_height="75dp"
                        android:background="@drawable/menu_box_t_log"
                        android:padding="18dp"
                        android:src="@drawable/ic_homework"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Homework"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>


                <!-- Result -->
                <LinearLayout
                    android:id="@+id/menu_result"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="75dp"
                        android:layout_height="75dp"
                        android:background="@drawable/menu_box_t_log"
                        android:padding="18dp"
                        android:src="@drawable/ic_result"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Result"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>


                <!-- Add Account -->
                <LinearLayout
                    android:id="@+id/menu_add_account"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="75dp"
                        android:layout_height="75dp"
                        android:background="@drawable/menu_box_t_log"
                        android:padding="18dp"
                        android:src="@drawable/ic_add_user"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add Account"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
                <!-- Event -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="75dp"
                        android:layout_height="75dp"
                        android:src="@drawable/event"
                        android:padding="18dp"
                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Event"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

            </GridLayout>

        </RelativeLayout>

    </ScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"

        app:itemIconSize="24dp"
        app:labelVisibilityMode="labeled"


        app:menu="@menu/bottom_menu"/>
</RelativeLayout>